# Copy to /opt/camera-server/.env, fill in, then: systemctl restart camera-server
# The deploy step generates the secrets for you.

CAMERA_DATA_DIR=/opt/camera-server/data

# python server.py gen-secret
CAMERA_SECRET=
# python server.py gen-secret  — the SAME value goes into the edge app config
CAMERA_DEVICE_TOKEN=
# python server.py hash-password 'your-pwa-password'
CAMERA_ADMIN_PASSWORD_HASH=

# Auto-delete clips older than N days (0 = keep forever). Disk on this box is small.
CAMERA_RETENTION_DAYS=30
# Also cap total storage in GB (0 = no cap); oldest clips deleted first when over.
CAMERA_MAX_GB=0

# nginx serves the video bytes via X-Accel-Redirect (1). Set 0 only for dev.
CAMERA_XACCEL=1

# Web Push (notifications phase) — python server.py gen-vapid
CAMERA_VAPID_PUBLIC=
CAMERA_VAPID_PRIVATE=
CAMERA_VAPID_SUBJECT=mailto:admin@your-domain.example
